{
  "name": "frontier-pulse-oracle",
  "version": "1.0.0",
  "description": "Oracle backend for Frontier Pulse — reads EVE Frontier World API, computes scores, writes to Sui smart contract",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "oracle:init": "tsx src/initOracle.ts",
    "oracle:run-once": "tsx src/index.ts --once"
  },
  "dependencies": {
    "@mysten/sui": "^2.12.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
